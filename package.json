{
  "name": "sitespresso",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "pwsh -ExecutionPolicy Bypass -File scripts/clean-dev.ps1",
    "dev:clean:start": "pwsh -ExecutionPolicy Bypass -File scripts/clean-dev.ps1 -StartDev",
    "dev:health": "pwsh -ExecutionPolicy Bypass -File scripts/dev-health.ps1",
    "test:smoke": "pwsh -ExecutionPolicy Bypass -File scripts/smoke-check.ps1",
    "test:reliability": "pwsh -ExecutionPolicy Bypass -File scripts/reliability-check.ps1",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "vercel-build": "next build",
    "clean": "pwsh -Command \"Get-Process node -ErrorAction SilentlyContinue | Stop-Process -Force -ErrorAction SilentlyContinue; Remove-Item -Recurse -Force .next -ErrorAction SilentlyContinue; Write-Host '✓ Cleaned'\"",
    "test:edges": "node scripts/test-slug-edge-cases.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "next": "^14.2.0",
    "openai": "^6.44.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "redis": "^6.0.0",
    "stripe": "^22.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "eslint-config-prettier": "^9.1.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2"
  }
}
